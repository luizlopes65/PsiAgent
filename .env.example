
# 🤖 Configurações do LLM (Ollama)
LLM_MODEL=ministral-3:3b
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434

# 🚀 API FastAPI
API_HOST=127.0.0.1
API_PORT=8001
DEBUG=true
RELOAD=true
LOG_LEVEL=info

# 🔧 MCP Server (Clinical Tools)
MCP_HOST=127.0.0.1
MCP_PORT=8000

# 🗄️ Banco de Dados
DATABASE_URL=sqlite:///./db/clinical_data.db


API_SECRET=admin


CORS_ORIGINS=*

# 📲 Timeouts (em segundos)
MCP_CONNECT_TIMEOUT=30
LLM_TIMEOUT=120
